{
  "template_name": "Medical Device License",
  "template_version": "1.0",
  "description": "IMDRF template for Health Canada Medical Device License applications",
  "regulation_type": "non_IVD",
  "created_date": "2024-01-01",
  "sections": [
    {
      "section_code": "1",
      "section_title": "Administrative Information",
      "section_description": "General administrative and applicant information",
      "is_required": true,
      "order_index": 1,
      "content_requirements": [
        "Applicant information",
        "Device identification",
        "Regulatory history"
      ],
      "children": [
        {
          "section_code": "1.1",
          "section_title": "Applicant Information",
          "section_description": "Details about the applicant organization",
          "is_required": true,
          "order_index": 1,
          "content_requirements": [
            "Company name and address",
            "Contact person details",
            "Business registration information"
          ]
        },
        {
