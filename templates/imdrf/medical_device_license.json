      "children": [
        {
          "section_code": "5.1",
          "section_title": "Clinical Evaluation",
          "section_description": "Clinical evaluation methodology and results",
          "is_required": true,
          "order_index": 1,
          "content_requirements": [
            "Clinical evaluation plan",
            "Literature review",
            "Clinical data analysis"
          ]
        },
        {
          "section_code": "5.2",
          "section_title": "Clinical Data",
          "section_description": "Clinical study data and reports",
          "is_required": false,
          "order_index": 2,
          "content_requirements": [
            "Clinical study protocols",
            "Clinical study reports",
            "Adverse event data"
          ]
        }
      ]
